{
  "name": "quota-gem",
  "version": "2.0.0",
  "description": "Windows tray utility for unified Claude, Codex, and Antigravity usage visibility under the QuotaGem brand.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "tauri": "tauri",
    "tauri:build": "tauri build",
    "package:portable": "powershell -ExecutionPolicy Bypass -File scripts/package-portable.ps1"
  },
  "keywords": [
    "tray",
    "windows",
    "claude",
    "codex",
    "antigravity",
    "usage",
    "quota",
    "react",
    "typescript"
  ],
  "author": "gyozalab",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "jsdom": "^29.0.1",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "wait-on": "^9.0.4"
  }
}
